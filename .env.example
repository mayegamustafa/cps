# ─────────────────────────────────────────────────────────────
# City Parents School Platform — environment template
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────

# Core
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://cps:cps_password@localhost:5432/cityparents?schema=public"

# API
# PaaS (Railway/Render) inject PORT automatically; API_PORT is the local fallback.
API_PORT=4000
API_URL=http://localhost:4000
WEB_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Default Super Admin (seeded once; change password after first login)
SEED_ADMIN_EMAIL=admin@cityparents.ac.ug
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_FIRST_NAME=Super
SEED_ADMIN_LAST_NAME=Admin

# Auth — JWT (use long random strings in production)
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Two-Factor Authentication (TOTP)
TOTP_ISSUER=City Parents School

# OAuth (optional — Google / Microsoft)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cityparents-media
R2_PUBLIC_URL=https://media.cityparents.sc.ug

# Live streaming (RTMP ingest + HLS delivery)
RTMP_INGEST_URL=rtmp://stream.cityparents.sc.ug/live
HLS_DELIVERY_URL=https://stream.cityparents.sc.ug/hls

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_SCHOOL_LAT=0.30537705324686104
NEXT_PUBLIC_SCHOOL_LNG=32.5637337974885

# SEO / indexing
NEXT_PUBLIC_SITE_URL=https://cityparents.sc.ug
# Public URL of the API (web reads this at BUILD time — set on the web service)
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app
GOOGLE_SEARCH_CONSOLE_KEY=
GOOGLE_INDEXING_SERVICE_ACCOUNT=

# Social aggregation
YOUTUBE_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
FACEBOOK_PAGE_TOKEN=
TIKTOK_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=

# Contact / WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=256700000000
CONTACT_EMAIL=info@cityparents.sc.ug

# Email (transactional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
